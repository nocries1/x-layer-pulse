# --- Network ---
NETWORK=mainnet                  # mainnet | testnet (signal data lives on mainnet only)
XLAYER_MAINNET_RPC=https://rpc.xlayer.tech
XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech
XLAYER_MAINNET_CHAIN_ID=196
XLAYER_TESTNET_CHAIN_ID=195

# --- Strategy ---
STRATEGY_MODE=demo               # demo | conservative
LOOP_INTERVAL_SECONDS=30
MIN_SIGNAL_USD=200               # ignore whale trades smaller than this
MIN_TRIGGER_WALLETS=2            # ignore signals fewer than N whales agree on
MAX_SLIPPAGE_PCT=1
COPY_SIZE_USDC=1                 # how many USDC to mirror per copy

# --- LLM (optional; loop falls back to heuristic without it) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- x402 risk feed (optional) ---
X402_RISK_URL=

# --- Server ---
SERVER_PORT=5174
